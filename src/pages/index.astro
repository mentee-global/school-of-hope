---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Crisis from "../components/Crisis.astro";
import Solution from "../components/Solution.astro";
import HowItWorks from "../components/HowItWorks.astro";
import InvestmentEfficiency from "../components/InvestmentEfficiency.astro";
import WhyDifferent from "../components/WhyDifferent.astro";
import FundingEntryPoints from "../components/FundingEntryPoints.astro";
import ImpactCycle from "../components/ImpactCycle.astro";
import ResearchCredibility from "../components/ResearchCredibility.astro";
import SDGs from "../components/SDGs.astro";
import IDGs from "../components/IDGs.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <main class="min-h-screen">
    <Hero />

    <div class="mx-6 md:mx-12 lg:mx-20">
      <div class="mx-auto max-w-7xl">
        <div class="h-px bg-gradient-to-r from-transparent via-[var(--teal)]/30 to-transparent"></div>
      </div>
    </div>

    <Crisis />

    <!-- All sections flow full-width -->
    <div class="space-y-14 px-6 py-8 md:px-12 lg:px-20">
      <div class="mx-auto max-w-7xl space-y-14">
        <Solution />
        <HowItWorks />
        <InvestmentEfficiency />
        <WhyDifferent />
        <FundingEntryPoints />
        <ImpactCycle />
        <ResearchCredibility />

        <!-- Frameworks -->
        <div>
          <SDGs />
          <IDGs />
        </div>

        <Contact />
      </div>
    </div>

    <Footer />
  </main>
</Layout>
