---
---

<section id="hero" class="relative overflow-hidden px-6 pt-2 pb-6 md:px-12 md:pt-4 lg:px-20 lg:pt-8 lg:pb-10">
  <!-- Subtle gradient glow -->
  <div class="pointer-events-none absolute -top-40 left-1/4 h-[500px] w-[500px] rounded-full bg-[var(--teal)] opacity-[0.04] blur-[120px]"></div>
  <div class="pointer-events-none absolute -top-20 right-1/4 h-[400px] w-[400px] rounded-full bg-[var(--gold)] opacity-[0.05] blur-[100px]"></div>

  <div class="relative mx-auto flex max-w-7xl flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
    <!-- Left: Title -->
    <div class="flex-1" data-animate="fade-left">
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.3em] text-theme-teal">
        A <a href="https://www.menteeglobal.org" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-theme-teal-hover">MENTEE</a> Initiative
      </p>
      <h1 class="mb-4">
        <span class="block font-serif text-5xl font-light italic text-theme-primary md:text-7xl lg:text-8xl">
          School
        </span>
        <span class="ml-12 block font-serif text-5xl font-light italic md:ml-20 md:text-7xl lg:text-8xl">
          <span class="bg-gradient-to-r from-[var(--gold)] to-[var(--gold-hover)] bg-clip-text text-transparent">of Hope</span>
        </span>
      </h1>
      <p class="mt-4 text-xs font-medium uppercase tracking-[0.25em] text-theme-secondary md:text-sm">
        Fully Remote &middot; U.S.-Accredited &middot; Trauma-Informed &middot; Crisis-Designed
      </p>
    </div>

    <!-- Right: 250M+ stat -->
    <div class="flex-shrink-0 text-right lg:pt-4" data-animate="fade-right">
      <p class="text-4xl font-bold md:text-6xl lg:text-7xl">
        <span class="bg-gradient-to-r from-[var(--gold)] to-[var(--teal)] bg-clip-text text-transparent">250M</span><span class="text-theme-teal">+</span>
      </p>
      <p class="mt-2 ml-auto max-w-[240px] text-base leading-relaxed text-theme-secondary">
        children out of school globally.<br />
        Crisis is the barrier.<br />
        <span class="font-semibold text-theme-primary">Hope is the solution.</span>
      </p>
    </div>
  </div>
</section>
