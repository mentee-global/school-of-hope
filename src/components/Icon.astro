---
import * as icons from "lucide";

interface Props {
  name: keyof typeof icons;
  size?: number;
  class?: string;
  strokeWidth?: number;
  id?: string;
}

const {
  name,
  size = 24,
  class: className = "",
  strokeWidth = 2,
  id,
} = Astro.props;

const iconData = icons[name];

if (!iconData || !Array.isArray(iconData)) {
  throw new Error(`Lucide icon "${name}" not found`);
}

function renderElements(elements: any[]): string {
  return elements
    .map(([tag, attrs]: [string, Record<string, string>]) => {
      const attrStr = Object.entries(attrs)
        .map(([k, v]) => `${k}="${v}"`)
        .join(" ");
      return `<${tag} ${attrStr} />`;
    })
    .join("");
}
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  id={id}
  set:html={renderElements(iconData as any[])}
/>
