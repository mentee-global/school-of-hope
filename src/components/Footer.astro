---
const badges = ["SDG-Aligned", "IDG-Aligned", "IRB-Backed", "US-Accredited"];
---

<footer class="relative px-6 py-10 md:px-12 lg:px-20">
  <!-- Gradient top border -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[var(--teal)]/40 to-transparent"></div>

  <div class="mx-auto max-w-7xl">
    <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
      <!-- Quote -->
      <blockquote class="max-w-lg" data-animate="fade-left">
        <p class="font-serif text-2xl italic leading-relaxed text-theme-secondary md:text-3xl">
          &ldquo;Geography no longer determines
          <span class="bg-gradient-to-r from-[var(--teal)] to-[var(--teal-hover)] bg-clip-text text-transparent">who gets to shape global solutions</span>.&rdquo;
        </p>
      </blockquote>

      <!-- Logo and link -->
      <div class="flex flex-col items-end gap-3" data-animate="fade-right">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 230 224"
          fill="currentColor"
          class="h-12 w-12 text-theme-primary"
          aria-label="MENTEE logo"
        >
          <rect x="72" y="0" width="17" height="224"/>
          <rect x="141" y="0" width="17" height="224"/>
          <rect x="106" y="0" width="18" height="82"/>
          <rect x="106" y="97" width="18" height="20"/>
          <rect x="106" y="133" width="18" height="91"/>
          <rect x="0" y="0" width="89" height="18"/>
          <rect x="141" y="0" width="89" height="18"/>
          <rect x="6" y="34" width="83" height="16"/>
          <rect x="141" y="34" width="83" height="16"/>
          <rect x="6" y="62" width="219" height="16"/>
          <rect x="6" y="78" width="13" height="58"/>
          <rect x="34" y="78" width="14" height="58"/>
          <rect x="183" y="78" width="14" height="58"/>
          <rect x="213" y="78" width="12" height="58"/>
          <rect x="72" y="78" width="87" height="4"/>
          <rect x="72" y="97" width="87" height="20"/>
          <rect x="72" y="132" width="87" height="4"/>
          <rect x="6" y="136" width="219" height="16"/>
          <rect x="8" y="182" width="81" height="17"/>
          <rect x="141" y="182" width="81" height="17"/>
          <rect x="6" y="208" width="83" height="16"/>
          <rect x="141" y="208" width="84" height="16"/>
        </svg>
        <a
          href="https://www.menteeglobal.org"
          target="_blank"
          rel="noopener noreferrer"
          class="text-base font-medium text-theme-teal transition-colors hover:text-theme-teal-hover"
        >
          www.menteeglobal.org
        </a>
      </div>
    </div>

    <!-- Badges -->
    <div class="mt-8 flex flex-wrap gap-3" data-animate>
      {
        badges.map((badge) => (
          <span class="rounded-full border border-theme px-4 py-1.5 text-xs font-medium uppercase tracking-wider text-theme-secondary transition-colors hover:border-[var(--teal)]/40 hover:text-theme-teal">
            {badge}
          </span>
        ))
      }
    </div>
  </div>
</footer>
